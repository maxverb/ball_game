# Piano Analytics API credentials (stay local, never commit)
PIANO_ACCESS_KEY=
PIANO_SECRET_KEY=
PIANO_SITE_ID=
PIANO_BASE_URL=https://api.atinternet.io/v3/data/getData

# Google Sheets goals (File -> Share -> Publish to web -> goals tab -> CSV)
GOOGLE_SHEET_CSV_URL=

# The exact source name Piano returns for Google Discover traffic.
# Run `npm run fetch:once` once to populate the cache, then inspect
# data/cache.json -> daily[] to find the actual string your Piano config uses.
GOOGLE_DISCOVER_SOURCE_KEY=google_discover

# Cache is considered stale after this many hours (auto-refetch on open)
MAX_CACHE_AGE_HOURS=6

# Express server port
SERVER_PORT=3001
